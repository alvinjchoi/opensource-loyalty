{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Loyalty Interchange Protocol",
  "description": "Open, vendor-neutral loyalty protocol and reference platform for restaurant, QSR, coffee, and franchise ordering systems.",
  "colors": {
    "primary": "#16A34A",
    "light": "#4ADE80",
    "dark": "#15803D"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "banner": {
    "content": "LIP 0.1.0 is on npm — `npx @loyalty-interchange/cli serve`",
    "dismissible": true
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "get-started/quickstart",
              "get-started/essentials"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/typescript-sdk",
              "guides/webhooks",
              "guides/customer-identity",
              "guides/reference-platform",
              "guides/postgres",
              "guides/migration",
              "guides/punchh-migration"
            ]
          },
          {
            "group": "AI & Agents",
            "pages": [
              "guides/using-lip-with-ai",
              "guides/ai-prompts"
            ]
          },
          {
            "group": "Protocol",
            "pages": [
              "protocol/overview"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Using the API",
            "pages": [
              "api-reference/overview"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "api-reference/openapi.yaml"
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Releases",
            "pages": [
              "changelog"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "npm",
        "href": "https://www.npmjs.com/org/loyalty-interchange"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/alvinjchoi/opensource-loyalty"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Quickstart",
      "href": "/get-started/quickstart"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/alvinjchoi/opensource-loyalty"
    }
  }
