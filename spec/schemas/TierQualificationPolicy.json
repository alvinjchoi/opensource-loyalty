{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loyalty-interchange.org/schema/v1/TierQualificationPolicy.json",
  "title": "TierQualificationPolicy",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "metric_id",
    "period"
  ],
  "properties": {
    "metric_id": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "description": "Opaque, stable identifier within the owning system.",
      "type": "string"
    },
    "period": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "type",
        "starts_month",
        "starts_day",
        "time_zone"
      ],
      "properties": {
        "type": {
          "const": "annual",
          "type": "string"
        },
        "starts_month": {
          "minimum": 1,
          "maximum": 12,
          "type": "integer"
        },
        "starts_day": {
          "minimum": 1,
          "maximum": 31,
          "type": "integer"
        },
        "time_zone": {
          "minLength": 1,
          "maxLength": 255,
          "type": "string"
        }
      }
    },
    "effective_from": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "type": "string"
    }
  }
}
