{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loyalty-interchange.org/schema/v1/IdentityReference.json",
  "title": "IdentityReference",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "type",
    "value"
  ],
  "properties": {
    "type": {
      "anyOf": [
        {
          "const": "loyalty_id",
          "type": "string"
        },
        {
          "const": "token",
          "type": "string"
        },
        {
          "const": "email_hash",
          "type": "string"
        },
        {
          "const": "phone_hash",
          "type": "string"
        },
        {
          "const": "external",
          "type": "string"
        }
      ]
    },
    "value": {
      "minLength": 1,
      "maxLength": 512,
      "type": "string"
    },
    "issuer": {
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "description": "Opaque, stable identifier within the owning system.",
      "type": "string"
    }
  }
}
