{
  "name": "@loyalty-interchange/mcp",
  "version": "0.1.1",
  "description": "Model Context Protocol server for Loyalty Interchange Protocol docs and validation.",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "git+https://github.com/alvinjchoi/opensource-loyalty.git", "directory": "packages/mcp" },
  "homepage": "https://github.com/alvinjchoi/opensource-loyalty#readme",
  "bugs": { "url": "https://github.com/alvinjchoi/opensource-loyalty/issues" },
  "engines": { "node": ">=22" },
  "publishConfig": { "access": "public", "provenance": true },
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./lib": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "bin": {
    "lip-mcp": "./dist/server.js"
  },
  "files": ["dist", "assets"],
  "scripts": {
    "build": "node ../../scripts/build-mcp-assets.mjs && tsc -b",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@loyalty-interchange/protocol": "0.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  }
}
